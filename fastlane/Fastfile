# frozen_string_literal: true

# Phase 203 — Fastlane Build/Ship Automation
#
# Four lanes: test, beta, release, screenshots.
# Recognized blockers (require user action):
#   1. Apple Developer Program enrollment ($99/yr)
#   2. Match repo creation (private GitHub repo for certs)
#   3. App Store Connect app record
# When these are unavailable, lanes run in --skip / --readonly stub mode.

default_bundle_id = "com.bretbouchard.volta"
volta_asc_apple_id = "6789455514"   # App Store Connect > App Information > Apple ID
volta_sku = "volta"                  # App Store Connect SKU

before_all do
  ensure_env_vars(
    APP_IDENTIFIER: default_bundle_id
  ) unless ENV["CI"].nil?
end

# =============================================================================
# Lane: test
# =============================================================================
# Runs the full validation pipeline before any build.
lane :test do |options|
  UI.message("Phase 203 — Running validation pipeline")

  # Swift tests via SPM (fast dev loop, no archive needed)
  Dir.chdir("../macos-app") do
    sh("swift test --no-parallel")
  end

  # Python daemon tests with coverage
  Dir.chdir("..") do
    sh("pytest --cov=volta --cov-fail-under=80")
  end

  UI.success("All tests pass")
end

# =============================================================================
# Lane: beta — Build and ship to TestFlight
# =============================================================================
# Recognized blocker: Apple Developer Program enrollment required for code signing.
# Run with `match readonly: true` to skip signing when stubbed.
lane :beta do |options|
  UI.message("Volta PCB — TestFlight build & upload")

  repo_root = File.expand_path("..", __dir__)

  # Generate Xcode project if missing.
  Dir.chdir("#{repo_root}/macos-app") do
    sh("xcodegen generate") unless File.exist?("VoltaPCB.xcodeproj")
  end

  # Build + sign the archive.
  # macOS App Store: archive signs with Apple Distribution, export produces
  # a .pkg which pilot uploads to TestFlight. The pkg signing uses the
  # Mac Installer Distribution cert (auto-generated by Xcode).
  build_app(
    scheme: "VoltaPCB",
    project: "#{repo_root}/macos-app/VoltaPCB.xcodeproj",
    export_method: "app-store",
    output_directory: "#{repo_root}/build",
    export_options: {
      provisioningProfiles: {
        "com.bretbouchard.volta" => "1240dfd2-e0f2-40d9-82c8-e749df43af36"
      },
      signingStyle: "manual"
    },
    xcargs: "-allowProvisioningUpdates -skipMacroValidation -skipPackagePluginValidation"
  )

  # Upload to TestFlight.
  if ENV["APP_STORE_CONNECT_API_KEY_ID"].nil?
    UI.important("ASC API key not set — skipping pilot upload")
  else
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_FILEPATH"],
      duration: 1200,
      in_house: false
    )
    pilot(
      app_identifier: default_bundle_id,
      apple_id: volta_asc_apple_id,
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  UI.success("Beta lane complete")
end

# =============================================================================
# Lane: release — Ship to App Store
# =============================================================================
lane :release do |options|
  UI.message("Phase 203 — App Store release")

  # Pre-release validation
  test

  # Upload to App Store Connect
  if ENV["APP_STORE_CONNECT_API_KEY_ID"].nil?
    UI.important("ASC API key not set — release requires enrollment")
    UI.user_error!("Cannot release without App Store Connect API key")
  else
    deliver(
      app_identifier: default_bundle_id,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_only: false
    )
  end

  UI.success("Release lane complete")
end

# =============================================================================
# Lane: screenshots — Snapshot via XCUITest
# =============================================================================
lane :screenshots do |options|
  UI.message("Phase 203 — Screenshot generation")

  # Phase 196.1 wires XCUITest; Phase 203 uses snapshot to capture them.
  if Dir.exist?("../macos-app/UITests")
    snapshot(
      scheme: "VoltaUITests",
      devices: ["Mac"],
      languages: ["en-US"],
      output_directory: "../fastlane/screenshots"
    )
  else
    UI.important("UITests target not found — Phase 196.1 wires XCUITest")
  end

  UI.success("Screenshots lane complete")
end

# =============================================================================
# Lane: certs — Generate signing certs via match (uses ASC API key auth)
# =============================================================================
desc "Generate distribution cert + provisioning profile via match"
lane :certs do |options|
  UI.message("Volta PCB — Generating signing certs")

  api_key = app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_filepath: ENV["APP_STORE_CONNECT_API_KEY_FILEPATH"],
    duration: 1200,
    in_house: false
  )

  match(
    type: "appstore",
    platform: "macos",
    app_identifier: default_bundle_id,
    api_key: api_key,
    git_url: "https://github.com/bretbouchard/VoltaCertRepo",
    generate_apple_certs: true,
    readonly: false
  )

  UI.success("Certs generated and stored in VoltaCertRepo")
end

# =============================================================================
# Lane: bootstrap — First-time setup
# =============================================================================
desc "First-time setup. Documents what user needs to do."
lane :bootstrap do |options|
  UI.message("Phase 203 — Bootstrap checklist")
  UI.message("")
  UI.message("Manual prerequisites (cannot be automated):")
  UI.message("  1. Apple Developer Program enrollment ($99/yr)")
  UI.message("     → https://developer.apple.com/programs/")
  UI.message("  2. Create match repo (private GitHub repo for certs)")
  UI.message("     → bundle exec fastlane match init")
  UI.message("  3. Create App Store Connect app record")
  UI.message("     → https://appstoreconnect.apple.com/")
  UI.message("  4. Generate ASC API key + set APP_STORE_CONNECT_API_KEY_ID env")
  UI.message("  5. Set MATCH_PASSWORD env var")
  UI.message("")
  UI.message("Once complete, run: fastlane beta")
end

# =============================================================================
# Lane: build — Debug build, no signing
# =============================================================================
# Phase 244: Debug build, no signing. Used for local dev iteration.
desc "Debug build with no signing (local dev)"
lane :build do |options|
  UI.message("Phase 244 — Debug build, no signing")

  repo_root = File.expand_path("..", __dir__)

  # Generate Xcode project if missing.
  Dir.chdir("#{repo_root}/macos-app") do
    sh("xcodegen generate") unless File.exist?("VoltaPCB.xcodeproj")
  end

  build_app(
    scheme: "VoltaPCB",
    project: "#{repo_root}/macos-app/VoltaPCB.xcodeproj",
    configuration: "Debug",
    skip_codesigning: true,
    skip_archive: true,
    skip_package_pkg: true,
    output_directory: "#{repo_root}/build",
    xcargs: "CODE_SIGN_IDENTITY=\"\" CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO"
  )

  UI.success("Debug build complete → #{repo_root}/build")
end

# =============================================================================
# Lane: build_release — Release build, signed, NOT notarized
# =============================================================================
# Phase 244: Release configuration, signed with match, no notarization
# (separate from beta which adds TestFlight upload).
desc "Release build, signed with match, not notarized"
lane :build_release do |options|
  UI.message("Phase 244 — Release build, signed")

  repo_root = File.expand_path("..", __dir__)

  # Generate Xcode project if missing.
  Dir.chdir("#{repo_root}/macos-app") do
    sh("xcodegen generate") unless File.exist?("VoltaPCB.xcodeproj")
  end

  # Sync signing certs from match repo
  if ENV["MATCH_PASSWORD"].nil?
    UI.important("MATCH_PASSWORD not set — running in cert-less mode")
  else
    match(
      type: "appstore",
      platform: "macos",
      app_identifier: default_bundle_id,
      readonly: true
    )
  end

  build_app(
    scheme: "VoltaPCB",
    project: "#{repo_root}/macos-app/VoltaPCB.xcodeproj",
    configuration: "Release",
    export_method: "app-store",
    output_directory: "#{repo_root}/build",
    xcargs: "-allowProvisioningUpdates -skipMacroValidation -skipPackagePluginValidation"
  )

  UI.success("Release build complete → #{repo_root}/build")
end

# =============================================================================
# Lane: snapshot — Generate App Store screenshots
# =============================================================================
# Phase 244: Capture screenshots for App Store metadata.
# Currently generates placeholder screenshots; UI test capture is Phase 196.1.
desc "Generate App Store screenshots"
lane :snapshot do |options|
  UI.message("Phase 244 — Screenshot generation")

  repo_root = File.expand_path("..", __dir__)
  output_dir = "#{repo_root}/fastlane/screenshots"
  FileUtils.mkdir_p(output_dir)

  # Try XCUITest-driven capture first.
  if Dir.exist?("#{repo_root}/macos-app/UITests")
    snapshot(
      scheme: "VoltaUITests",
      devices: ["Mac"],
      languages: ["en-US"],
      output_directory: output_dir
    )
  else
    # Placeholder mode: generate 5 PNG stubs (one per required size).
    # Phase 196.1 replaces this with real XCUITest capture.
    UI.important("UITests not found — generating placeholder screenshots")
    sizes = [
      ["1280x800", 1280, 800],
      ["1440x900", 1440, 900],
      ["1680x1050", 1680, 1050],
      ["1920x1080", 1920, 1080],
      ["2560x1600", 2560, 1600],
    ]
    sizes.each_with_index do |(name, w, h), i|
      path = "#{output_dir}/en-US/#{w}x#{h}.png"
      FileUtils.mkdir_p(File.dirname(path))
      # Minimal 1×1 PNG (placeholder). Phase 196.1 will replace.
      png_bytes = [
        0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,  # signature
        0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,  # IHDR
        0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,  # 1x1
        0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4, 0x89,
        0x00, 0x00, 0x00, 0x0D, 0x49, 0x44, 0x41, 0x54,
        0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00, 0x05,
        0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4,
        0x00, 0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44,
        0xAE, 0x42, 0x60, 0x82,
      ]
      File.binwrite(path, png_bytes.pack("C*"))
      UI.message("  → #{path}")
    end
  end

  UI.success("Screenshots complete → #{output_dir}")
end

# =============================================================================
# Lane: build_daemon — PyInstaller daemon build + codesign
# =============================================================================
# Phase 244: Build the volta-daemon via PyInstaller, then apply hardened
# runtime + Developer ID signature.
desc "Build the volta-daemon with PyInstaller and codesign"
lane :build_daemon do |options|
  UI.message("Phase 244 — Build + sign volta-daemon")

  repo_root = File.expand_path("..", __dir__)

  # Run PyInstaller
  Dir.chdir("#{repo_root}/volta-0.1.0") do
    sh("pyinstaller --noconfirm --onedir --name volta-daemon src/volta/daemon/main.py") ||
      UI.user_error!("PyInstaller build failed")
  end

  # Re-sign the binary + every dylib inside _internal/ with a single identity
  # (see Scripts/resign_kicad_daemon.sh for why)
  sh("bash #{repo_root}/Scripts/resign_kicad_daemon.sh") ||
    UI.user_error!("Re-sign failed")

  # Hardened-runtime + Developer ID signature
  if ENV["DEVELOPER_ID"].nil?
    UI.important("DEVELOPER_ID not set — skipping codesign")
  else
    sh(
      "codesign --force --deep --options runtime " \
      "--sign \"#{ENV['DEVELOPER_ID']}\" " \
      "#{repo_root}/volta-0.1.0/dist/volta-daemon"
    )
  end

  UI.success("Daemon built + signed → dist/volta-daemon")
end
