<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Phase 166 — BYOK Keychain Storage
      Per MOD-05: app makes direct HTTPS calls to LLM providers. Required
      for outbound network (URLSession).
    -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!--
      Per MOD-04: API keys in Keychain. macOS sandboxed apps get keychain
      access automatically — keychain-access-groups entitlement is rejected
      by App Store for macOS (iOS only). Use the default keychain group.
    -->
    <key>com.apple.security.network.server</key>
    <false/>
    <!--
      Phase 168+ — file write access for KiCad file operations. User-selected
      files only (no broad file system access).
    -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
