# Source: Authored from published numeric specifications
# License: No license — authored from published numeric specifications
# Last verified: 2026-07-10
# Vendor: AISLER 4-Layer
# Capabilities: min track 0.15mm, min clearance 0.15mm, min drill 0.2mm, min annular 0.2mm
(version 1)
(rule "Minimum track width"
    (constraint track_width (min 0.15mm))
)
(rule "Minimum clearance"
    (constraint clearance (min 0.15mm))
)
(rule "Minimum hole size"
    (constraint hole_size (min 0.2mm))
)
(rule "Minimum annular ring"
    (constraint annular_width (min 0.2mm))
)
(rule "Minimum via diameter"
    (constraint via_diameter (min 0.45mm))
)
