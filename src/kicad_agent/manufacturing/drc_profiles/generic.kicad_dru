# Source: Conservative defaults for unknown vendors
# License: N/A — data
# Last verified: 2026-07-10
# Vendor: Generic Conservative
# Capabilities: min track 0.2mm, min clearance 0.2mm, min drill 0.4mm, min annular 0.15mm
(version 1)
(rule "Minimum track width"
    (constraint track_width (min 0.2mm))
)
(rule "Minimum clearance"
    (constraint clearance (min 0.2mm))
)
(rule "Minimum hole size"
    (constraint hole_size (min 0.4mm))
)
(rule "Minimum annular ring"
    (constraint annular_width (min 0.15mm))
)
(rule "Minimum via diameter"
    (constraint via_diameter (min 0.6mm))
)
