(version 1)
(rule "Minimum track width"
    (constraint track_width (min 0.1524mm))
)
(rule "Minimum clearance"
    (constraint clearance (min 0.1524mm))
)
(rule "Minimum hole size"
    (constraint hole_size (min 0.3556mm))
)
(rule "Minimum annular ring"
    (constraint annular_width (min 0.1524mm))
)
(rule "Minimum via diameter"
    (constraint via_diameter (min 0.6604mm))
)
